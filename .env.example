# Kakeez — environment variable template.
# Copy this file to .env.local and fill in real values for local development.
# .env.local is .gitignored; never commit real credentials.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (public — safe to ship to the browser)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# Supabase service role (SECRET — server-only).
# Used by src/lib/supabase/admin.ts for privileged ops (admin RPCs, seed,
# Edge Function fallbacks). NEVER import the admin client from a
# "use client" file. Never expose this key in any NEXT_PUBLIC_* variable.
# Rotate via Supabase Dashboard → Project Settings → API if it leaks.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-server-only

# Transactional notifications
# In development, keep NOTIFICATIONS_DRY_RUN=true so emails/WhatsApp messages
# are logged and marked sent without external credentials.
NOTIFICATIONS_DRY_RUN=true
NOTIFICATIONS_PROCESS_SECRET=change-me-long-random-secret

# Google SMTP / Gmail app-password SMTP.
GOOGLE_SMTP_HOST=smtp.gmail.com
GOOGLE_SMTP_PORT=465
GOOGLE_SMTP_SECURE=true
GOOGLE_SMTP_USER=your-google-workspace-smtp-user
GOOGLE_SMTP_PASS=your-google-app-password
GOOGLE_SMTP_FROM=orders@kakeez.com
KAKEEZ_ADMIN_EMAIL=orders@kakeez.com

# WhatsApp Cloud API admin alerts.
WHATSAPP_API_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
KAKEEZ_ADMIN_WHATSAPP_E164=923001234567
