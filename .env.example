# Kakeez — environment variable template.
# Copy this file to .env.local and fill in real values for local development.
# .env.local is .gitignored; never commit real credentials.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (public — safe to ship to the browser)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# Supabase service role (SECRET — server-only).
# Used by src/lib/supabase/admin.ts for privileged ops (admin RPCs, seed,
# Edge Function fallbacks). NEVER import the admin client from a
# "use client" file. Never expose this key in any NEXT_PUBLIC_* variable.
# Rotate via Supabase Dashboard → Project Settings → API if it leaks.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-server-only
